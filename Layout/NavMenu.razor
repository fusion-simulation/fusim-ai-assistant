@inject ClientSessionService Session
@inject NavigationManager Navigation
@implements IDisposable

<nav class="shell-nav">
    @if (Session.IsLoggedIn)
    {
        <NavLink class="shell-link" href="/" Match="NavLinkMatch.All">主页</NavLink>
        <NavLink class="shell-link" href="/new-case">新建算例</NavLink>
        <NavLink class="shell-link" href="/cases">算例列表</NavLink>
        <div class="shell-user">用户: @Session.Username (@Session.UserId)</div>
        <button type="button" class="shell-logout" @onclick="Logout">退出登录</button>
    }
    else
    {
        <NavLink class="shell-link" href="/login" Match="NavLinkMatch.All">登录</NavLink>
    }
</nav>

@code {
    protected override void OnInitialized()
    {
        Session.SessionChanged += HandleSessionChanged;
    }

    private void HandleSessionChanged() => InvokeAsync(StateHasChanged);

    private void Logout()
    {
        Session.SignOut();
        Navigation.NavigateTo("/login", forceLoad: false);
    }

    public void Dispose()
    {
        Session.SessionChanged -= HandleSessionChanged;
    }
}
