@page "/login"
@using Microsoft.AspNetCore.Components
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.JSInterop
@inject IJSRuntime JS
@inject NavigationManager Navigation

<PageTitle>登录</PageTitle>

<div class="login-container">
    <div class="ambient-glow"></div>
    <div class="login-card">
        <h1>vmom2 测试登录</h1>
        <p>本项目为测试环境，仅支持 `guest/guest`。</p>

        <EditForm Model="model" OnValidSubmit="HandleLogin">
            <DataAnnotationsValidator />

            <div class="form-group">
                <label for="username" class="input-label">账号</label>
                <InputText id="username" class="input-field" @bind-Value="model.Username" />
            </div>

            <div class="form-group">
                <label for="password" class="input-label">密码</label>
                <InputText id="password" type="password" class="input-field" @bind-Value="model.Password" />
            </div>

            @if (!string.IsNullOrWhiteSpace(errorMessage))
            {
                <div class="error-message">@errorMessage</div>
            }

            <button type="submit" class="submit-btn" disabled="@isSubmitting">
                @(isSubmitting ? "登录中..." : "登录")
            </button>
        </EditForm>
    </div>
</div>

@code {
    [CascadingParameter]
    private Task<AuthenticationState>? AuthenticationStateTask { get; set; }

    [SupplyParameterFromQuery(Name = "returnUrl")]
    public string? ReturnUrl { get; set; }

    private readonly LoginFormModel model = new() { Username = "guest", Password = "guest" };
    private bool isSubmitting;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        if (AuthenticationStateTask is null)
        {
            return;
        }

        var authenticationState = await AuthenticationStateTask;
        if (authenticationState.User.Identity?.IsAuthenticated == true)
        {
            Navigation.NavigateTo(GetTargetUrl(), forceLoad: true);
        }
    }

    private async Task HandleLogin()
    {
        try
        {
            isSubmitting = true;
            errorMessage = null;

            var payload = await JS.InvokeAsync<LoginResponse>("authManager.login", model.Username, model.Password);
            if (!payload.Success)
            {
                errorMessage = payload.Message;
                return;
            }

            Navigation.NavigateTo(GetTargetUrl(), forceLoad: true);
        }
        catch (Exception)
        {
            errorMessage = "登录失败，请使用 guest/guest。";
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private string GetTargetUrl()
    {
        return string.IsNullOrWhiteSpace(ReturnUrl) ? "/" : ReturnUrl;
    }

    private class LoginFormModel
    {
        public string Username { get; set; } = string.Empty;
        public string Password { get; set; } = string.Empty;
    }
}
