@page "/login"
@inject HttpClient Http
@inject ClientSessionService Session
@inject NavigationManager Navigation

<PageTitle>登录</PageTitle>

<div class="login-container">
    <div class="ambient-glow"></div>
    <div class="login-card">
        <h1>vmom2 测试登录</h1>
        <p>本项目为测试环境，仅支持 `guest/guest`。</p>

        <EditForm Model="model" OnValidSubmit="HandleLogin">
            <DataAnnotationsValidator />

            <div class="form-group">
                <label for="username" class="input-label">账号</label>
                <InputText id="username" class="input-field" @bind-Value="model.Username" />
            </div>

            <div class="form-group">
                <label for="password" class="input-label">密码</label>
                <InputText id="password" type="password" class="input-field" @bind-Value="model.Password" />
            </div>

            @if (!string.IsNullOrWhiteSpace(errorMessage))
            {
                <div class="error-message">@errorMessage</div>
            }

            <button type="submit" class="submit-btn" disabled="@isSubmitting">
                @(isSubmitting ? "登录中..." : "登录")
            </button>
        </EditForm>
    </div>
</div>

@code {
    private readonly LoginFormModel model = new() { Username = "guest", Password = "guest" };
    private bool isSubmitting;
    private string? errorMessage;

    protected override void OnInitialized()
    {
        if (Session.IsLoggedIn)
        {
            Navigation.NavigateTo("/", forceLoad: false);
        }
    }

    private async Task HandleLogin()
    {
        try
        {
            isSubmitting = true;
            errorMessage = null;

            var response = await Http.PostAsJsonAsync("api/auth/login", new LoginRequest(model.Username, model.Password));
            if (!response.IsSuccessStatusCode)
            {
                errorMessage = "登录失败，请使用 guest/guest。";
                return;
            }

            var payload = await response.Content.ReadFromJsonAsync<LoginResponse>();
            if (payload is null || !payload.Success)
            {
                errorMessage = payload?.Message ?? "登录失败。";
                return;
            }

            Session.SignIn(model.Username, payload.UserId);
            Navigation.NavigateTo("/", forceLoad: false);
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private class LoginFormModel
    {
        public string Username { get; set; } = string.Empty;
        public string Password { get; set; } = string.Empty;
    }
}
