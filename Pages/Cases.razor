@page "/cases"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inject HttpClient Http
@inject NavigationManager Navigation
@using Microsoft.AspNetCore.SignalR.Client
@implements IAsyncDisposable

<PageTitle>算例列表</PageTitle>

@if (!isReady)
{
    <div class="loading-box">加载算例中...</div>
}
else
{
    <div class="cases-container">
        <div class="panel-head">
            <h2 class="page-title">算例列表</h2>
        </div>

        @if (!string.IsNullOrWhiteSpace(errorMessage))
        {
            <div class="alert alert-danger">@errorMessage</div>
        }
        else if (cases.Count == 0)
        {
            <div class="empty-hint">暂无算例。</div>
        }
        else
        {
            <table class="cases-table">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>标题</th>
                        <th>状态</th>
                        <th>操作</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in cases)
                    {
                        <tr class="case-row">
                            <td>@item.Id</td>
                            <td>@item.Title</td>
                            <td><span class="status-tag status-@item.Status">@item.Status</span></td>
                            <td class="action-cell">
                                <button type="button"
                                        class="action-btn"
                                        disabled="@(item.Status.Equals("success", StringComparison.OrdinalIgnoreCase) ? false : true)"
                                        @onclick="() => ViewCaseDetails(item.Id)">查看结果</button>
                                <button type="button"
                                        class="action-btn-secondary"
                                        disabled="@(item.Status.Equals("success", StringComparison.OrdinalIgnoreCase) ? false : true)"
                                        @onclick="() => BeginDownloadCase(item.Id)">下载 zip</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>

    @if (!string.IsNullOrWhiteSpace(downloadUrl))
    {
        <iframe class="download-frame" src="@downloadUrl" title="case-download"></iframe>
    }
}

@code {
    private bool isReady;
    private string? errorMessage;
    private IReadOnlyList<CaseListItem> cases = Array.Empty<CaseListItem>();
    private string? downloadUrl;
    private HubConnection? hubConnection;

    protected override async Task OnInitializedAsync()
    {
        await LoadCasesAsync();
        isReady = true;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        try
        {
            await ConnectHubAsync();
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task LoadCasesAsync()
    {
        errorMessage = null;

        try
        {
            cases = await Http.GetFromJsonAsync<IReadOnlyList<CaseListItem>>("api/vmom/cases")
                ?? Array.Empty<CaseListItem>();
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
            cases = Array.Empty<CaseListItem>();
        }
    }

    private async Task ConnectHubAsync()
    {
        hubConnection = new HubConnectionBuilder()
            .WithUrl(Navigation.ToAbsoluteUri("/hubs/case-status"))
            .WithAutomaticReconnect()
            .Build();

        hubConnection.On<IReadOnlyList<CaseListItem>>("CasesUpdated", async data =>
        {
            cases = data;
            errorMessage = null;
            isReady = true;
            await InvokeAsync(StateHasChanged);
        });

        hubConnection.Reconnected += async _ =>
        {
            try
            {
                await SubscribeCasesAsync();
                errorMessage = null;
            }
            catch (Exception ex)
            {
                errorMessage = ex.Message;
            }

            await InvokeAsync(StateHasChanged);
        };

        await hubConnection.StartAsync();
        await SubscribeCasesAsync();
    }

    private Task SubscribeCasesAsync()
    {
        return hubConnection is null
            ? Task.CompletedTask
            : hubConnection.InvokeAsync("SubscribeCases");
    }

    private void ViewCaseDetails(int caseId)
    {
        Navigation.NavigateTo($"/cases/{caseId}");
    }

    private void BeginDownloadCase(int caseId)
    {
        downloadUrl = $"api/vmom/cases/{caseId}/download?ts={DateTimeOffset.UtcNow.ToUnixTimeMilliseconds()}";
    }

    public async ValueTask DisposeAsync()
    {
        if (hubConnection is not null)
        {
            try
            {
                await hubConnection.DisposeAsync();
            }
            catch (Exception)
            {
                // Ignore errors while disconnecting.
            }
        }
    }
}
