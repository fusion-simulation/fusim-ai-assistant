@page "/cases/{Id:int}"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inject HttpClient Http
@inject NavigationManager Navigation
@using Markdig
@using Microsoft.AspNetCore.Components
@using FusimAiAssiant.Services

<PageTitle>算例详情</PageTitle>

<div class="case-detail-page">
    <section class="detail-container">
        <div class="panel-head">
            <h2 class="page-title">
                <button class="back-btn" @onclick="GoBack">←</button>
                算例结果 (ID: @Id)
            </h2>
            <button type="button"
                    class="action-btn-secondary"
                    disabled="@(selectedCase?.Status.Equals("success", StringComparison.OrdinalIgnoreCase) != true)"
                    @onclick="BeginDownloadCase">下载当前算例 zip</button>
        </div>

        @if (!isReady)
        {
            <div class="loading-box detail-state-box">加载详情中...</div>
        }
        else if (errorMessage != null)
        {
            <div class="detail-state-box">
                <div class="alert-danger">@errorMessage</div>
            </div>
        }
        else if (selectedCase != null)
        {
            <div class="detail-body">
                @if (!string.IsNullOrWhiteSpace(selectedCase.ErrorMessage))
                {
                    <div class="alert-warning">@selectedCase.ErrorMessage</div>
                }

                <section class="result-panel">
                    <div class="info-bar">
                        <span class="mono">状态: </span>
                        <span class="status-tag status-@selectedCase.Status">@selectedCase.Status</span>
                    </div>

                    <div class="file-views">
                        <details open>
                            <summary>RZ.txt</summary>
                            <pre class="file-preview">@selectedCase.RzText</pre>
                        </details>

                        <details>
                            <summary>eqpr_iota.txt</summary>
                            <pre class="file-preview">@selectedCase.EqprIotaText</pre>
                        </details>

                        <details>
                            <summary>vmom.out</summary>
                            <pre class="file-preview">@selectedCase.VmomOutText</pre>
                        </details>
                    </div>
                </section>
            </div>
        }
    </section>

    <aside class="chat-shell">
        <section class="chat-panel">
            <div class="chat-panel-glow"></div>

            <div class="chat-head">
                <div class="chat-head-main">
                    <div class="chat-head-copy">
                        <div class="chat-eyebrow">AI Agent</div>
                        <h3>算例助手</h3>
                    </div>
                    <button type="button"
                            class="chat-reset-btn"
                            title="新建会话并清空当前上下文"
                            aria-label="新建会话并清空当前上下文"
                            disabled="@isChatBusy"
                            @onclick="ResetChatContext">+</button>
                </div>
                <p>@AssistantReadyHint</p>
            </div>

            @if (!isReady)
            {
                <div class="chat-empty-state">加载算例详情后启用助手...</div>
            }
            else if (errorMessage != null || selectedCase is null)
            {
                <div class="chat-empty-state">当前算例详情不可用，助手暂时不可用。</div>
            }
            else
            {
                <div class="chat-messages">
                    @foreach (var message in displayedChatMessages)
                    {
                        <div class="chat-row @(message.IsUser ? "chat-row-user" : "chat-row-agent")">
                            <div class="chat-item @(message.IsUser ? "chat-user" : "chat-agent") @(message.IsWaiting ? "chat-waiting" : string.Empty)">
                                <div class="chat-role">@(message.IsUser ? "你" : "助手")</div>
                                @if (message.IsWaiting)
                                {
                                    <div class="chat-waiting-status" aria-live="polite">
                                        <span class="chat-waiting-label">@message.Content</span>
                                        <span class="chat-waiting-dots" aria-hidden="true">
                                            <span></span>
                                            <span></span>
                                            <span></span>
                                        </span>
                                    </div>
                                }
                                else if (message.IsUser)
                                {
                                    <div class="chat-text user-text">@message.Content</div>
                                }
                                else
                                {
                                    <div class="chat-text markdown-text">@RenderAssistantMarkdown(ChatMessageFormatter.NormalizeAssistantContent(message.Content, message.ImageUrl))</div>
                                }
                                @if (!string.IsNullOrWhiteSpace(message.ImageUrl))
                                {
                                    <button type="button"
                                            class="chat-image-trigger"
                                            title="点击放大图片"
                                            aria-label="放大图片"
                                            @onclick="@(() => OpenImagePreview(message.ImageUrl))">
                                        <img class="chat-image" src="@message.ImageUrl" alt="plot-image" />
                                    </button>
                                }
                            </div>
                        </div>
                    }
                </div>

                <form class="chat-composer" @onsubmit="SendChatAsync">
                    <textarea class="chat-input"
                              placeholder="描述你要分析的问题..."
                              @bind="chatInput"
                              disabled="@isChatBusy"></textarea>

                    <div class="chat-composer-footer">
                        <div class="chat-shortcut-selector" aria-label="快捷指令">
                            <select class="shortcut-select"
                                    value="@selectedShortcut"
                                    @onchange="OnShortcutSelected"
                                    disabled="@isChatBusy">
                                <option value="@ShortcutPlaceholder">选择快捷指令...</option>
                                @foreach (var shortcut in ShortcutCommands)
                                {
                                    <option value="@shortcut">@shortcut</option>
                                }
                            </select>
                        </div>
                        <button type="submit" class="chat-send-btn" disabled="@isChatBusy">发送</button>
                    </div>
                </form>
            }
        </section>
    </aside>

    @if (!string.IsNullOrWhiteSpace(downloadUrl))
    {
        <iframe class="download-frame" src="@downloadUrl" title="case-download"></iframe>
    }

    @if (imagePreviewState.IsOpen && !string.IsNullOrWhiteSpace(imagePreviewState.ImageUrl))
    {
        <div class="image-preview-overlay" @onclick="CloseImagePreview">
            <div class="image-preview-dialog"
                 role="dialog"
                 aria-modal="true"
                 aria-label="图片预览"
                 tabindex="0"
                 @onclick:stopPropagation="true"
                 @onkeydown="HandleImagePreviewKeyDown"
                 @ref="imagePreviewDialogRef">
                <button type="button"
                        class="image-preview-close"
                        aria-label="关闭图片预览"
                        @onclick="CloseImagePreview">×</button>
                <img class="image-preview-full"
                     src="@imagePreviewState.ImageUrl"
                     alt="enlarged-plot-image" />
            </div>
        </div>
    }
</div>

@code {
    private static readonly IReadOnlyList<string> ShortcutCommands = CaseAgentShortcutCatalog.DefaultShortcuts;
    private const string AssistantReadyHint = "可分析结果、解释异常并生成绘图请求";
    private const string ShortcutPlaceholder = "";

    [Parameter]
    public int Id { get; set; }

    private bool isReady;
    private string? errorMessage;
    private VmomCaseDetail? selectedCase;
    private string? downloadUrl;
    private string selectedShortcut = ShortcutPlaceholder;
    private string chatInput = string.Empty;
    private bool isChatBusy;
    private readonly List<CaseAgentChatMessage> chatMessages = [];
    private readonly CaseImagePreviewState imagePreviewState = new();
    private ElementReference imagePreviewDialogRef;
    private bool shouldFocusImagePreview;
    private IReadOnlyList<CaseDetailChatDisplayItem> displayedChatMessages = Array.Empty<CaseDetailChatDisplayItem>();
    private static readonly MarkdownPipeline MarkdownPipeline = new MarkdownPipelineBuilder()
        .UseAdvancedExtensions()
        .DisableHtml()
        .Build();

    protected override async Task OnInitializedAsync()
    {
        await LoadCaseAsync();
        isReady = true;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!shouldFocusImagePreview || !imagePreviewState.IsOpen)
        {
            return;
        }

        shouldFocusImagePreview = false;
        await imagePreviewDialogRef.FocusAsync();
    }

    private async Task LoadCaseAsync()
    {
        errorMessage = null;
        try
        {
            selectedCase = await Http.GetFromJsonAsync<VmomCaseDetail>($"api/vmom/cases/{Id}");
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
            selectedCase = null;
        }
    }

    private async Task SendChatAsync()
    {
        if (isChatBusy || string.IsNullOrWhiteSpace(chatInput))
        {
            return;
        }

        var input = chatInput.Trim();
        var requestHistory = chatMessages.ToArray();
        chatInput = string.Empty;
        chatMessages.Add(new CaseAgentChatMessage("user", input, null));
        isChatBusy = true;
        RefreshDisplayedChatMessages();

        try
        {
            var response = await Http.PostAsJsonAsync(
                $"api/vmom/cases/{Id}/agent/chat",
                new CaseAgentChatRequest(input, requestHistory));

            if (!response.IsSuccessStatusCode)
            {
                chatMessages.Add(new CaseAgentChatMessage("assistant", $"请求失败: {(int)response.StatusCode}", null));
                return;
            }

            var data = await response.Content.ReadFromJsonAsync<CaseAgentChatResponse>();
            if (data is null)
            {
                chatMessages.Add(new CaseAgentChatMessage("assistant", "助手返回为空。", null));
                return;
            }

            chatMessages.Add(new CaseAgentChatMessage("assistant", data.Answer, data.ImageUrl));
        }
        catch (Exception ex)
        {
            chatMessages.Add(new CaseAgentChatMessage("assistant", $"调用异常: {ex.Message}", null));
        }
        finally
        {
            isChatBusy = false;
            RefreshDisplayedChatMessages();
        }
    }

    private void BeginDownloadCase()
    {
        downloadUrl = $"api/vmom/cases/{Id}/download?ts={DateTimeOffset.UtcNow.ToUnixTimeMilliseconds()}";
    }

    private void OnShortcutSelected(ChangeEventArgs args)
    {
        var shortcut = args.Value?.ToString() ?? ShortcutPlaceholder;
        selectedShortcut = shortcut;

        if (string.IsNullOrWhiteSpace(shortcut))
        {
            return;
        }

        chatInput = CaseAgentShortcutCatalog.ApplyShortcut(chatInput, shortcut);
        selectedShortcut = ShortcutPlaceholder;
    }

    private void GoBack()
    {
        Navigation.NavigateTo("/cases");
    }

    private void ResetChatContext()
    {
        if (isChatBusy)
        {
            return;
        }

        chatMessages.Clear();
        chatInput = string.Empty;
        selectedShortcut = ShortcutPlaceholder;
        CloseImagePreview();
        RefreshDisplayedChatMessages();
    }

    private void OpenImagePreview(string? imageUrl)
    {
        imagePreviewState.Open(imageUrl);
        shouldFocusImagePreview = imagePreviewState.IsOpen;
    }

    private void CloseImagePreview()
    {
        imagePreviewState.Close();
        shouldFocusImagePreview = false;
    }

    private void HandleImagePreviewKeyDown(KeyboardEventArgs args)
    {
        if (string.Equals(args.Key, "Escape", StringComparison.Ordinal))
        {
            CloseImagePreview();
        }
    }

    private static MarkupString RenderAssistantMarkdown(string content)
    {
        var html = Markdown.ToHtml(content ?? string.Empty, MarkdownPipeline);
        return new MarkupString(html);
    }

    private void RefreshDisplayedChatMessages()
    {
        displayedChatMessages = CaseDetailChatViewBuilder.Build(chatMessages, isChatBusy);
    }
}
